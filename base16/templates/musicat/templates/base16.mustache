display-name: Base16 {{scheme-name}}
variant: {{scheme-variant}}

# ─── Core palette ────────────────────────────────────────────────────────────
# Dynamic Base16 Template
window:          "#{{base01-hex}}"    # Background (Alternate Dark)
panel:           "#{{base00-hex}}b3"  # Default Background with legacy alpha
overlay:         "#{{base02-hex}}88"  # Selection Background with legacy alpha

soft:            "#{{base03-hex}}"    # Comments, Invisibles, Highlighting
solid:           "#{{base00-hex}}"    # Default Background

shadow:          "#00000033"          
shadow-soft:     "#0000001a"

accent:          "#{{base09-hex}}"    # Integers, Boolean, Constants (Orange-ish)
accent-text:     "#{{base00-hex}}"    # High contrast return to background

accent-soft:     "#{{base0F-hex}}cc"  # Deprecated, Opening/Closing Embedded Tags
accent-softer:   "#{{base0F-hex}}bb"  
accent-softest:  "#{{base0A-hex}}11"  # Classes, Keywords (Yellow-ish)

accent-play:     "#{{base0B-hex}}"    # Strings, Inherited Class (Green-ish)
accent-love:     "#{{base08-hex}}"    # Variables, XML Tags (Red-ish)

library-hover:   "#{{base03-hex}}99"  
library-highlight: "#{{base0C-hex}}cc" # Support, Regular Expressions (Cyan-ish)

menu:            "#{{base01-hex}}cc"  
menu-hover:      "#{{base05-hex}}11"  

shuffle:         "#{{base0E-hex}}"    # Operators, Punctuation (Purple-ish)
repeat:          "#{{base0B-hex}}"    

waveform:        "#{{base0D-hex}}"    # Functions, Methods (Blue-ish)
waveform-progress: "#{{base0C-hex}}"  

primary:         "#{{base05-hex}}ee"  # Default Text
secondary:       "#{{base0E-hex}}"    # Operators/Secondary Text
muted:           "#{{base05-hex}}66"  
inactive:        "#{{base02-hex}}"    # Selection Background

border:          "#{{base05-hex}}22"  # Subtle borders using text color
destructive:     "#{{base08-hex}}"    # Base08 (Red)
positive:        "#{{base0B-hex}}"    # Base0B (Green)
warning:         "#{{base09-hex}}"    # Base09 (Orange)